# Email Configuration for Contact Form (Resend)
# Copy this to .env.local and fill in your values

# Resend API Configuration (Recommended)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=Stratoma Contact <onboarding@resend.dev>
RESEND_TO=stratoma.ai@gmail.com

# Legacy SMTP Configuration (No longer used - migrated to Resend)
# EMAIL_HOST=mail.stratomai.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=info@stratomai.com
# EMAIL_PASS=your_password_here
# EMAIL_FROM=info@stratomai.com
# EMAIL_TO=your_destination_email@example.com

# ---------------------------------------------------------------------------
# Panel Dashboard (/panel) — Supabase Auth (Supabase Stratoma self-hosted)
# ---------------------------------------------------------------------------
# Public (safe to expose to the browser bundle):
NEXT_PUBLIC_SUPABASE_URL=https://supabasekong-xxxxxxxx.sslip.io
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your_anon_key

# Server-only (NEVER expose). Used for the admin invite-user flow:
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your_service_role_key
